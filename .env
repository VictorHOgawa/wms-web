# URL do Adapta Hub (identidade). O wms-frontend roda no navegador da mesma
# máquina, então localhost alcança os backends direto (sem tunnel).
VITE_HUB_API_URL=http://localhost:3334
# Override do spoke: o tenant no Hub pode apontar para um tunnel (celular);
# no navegador local usamos o spoke em localhost.
VITE_SPOKE_API_URL=http://localhost:3333
